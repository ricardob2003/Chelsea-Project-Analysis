# PostgreSQL connection (used by FastAPI + SQLAlchemy)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Port 5434 is mapped from Docker (see docker-compose.yml)
DATABASE_URL=postgresql://pl-user:yourpassword@localhost:5434/pl-team-datamart

# Docker Compose variables (used by docker-compose.yml)
DB_NAME=pl-team-datamart
DB_USER=pl-user
DB_PASSWORD=yourpassword
FD_API_KEY=your_football_data_api_key
